pacman::p_load(
dplyr,
tidyr,
janitor,
skimr,
stringr
)
#| eval: true
library(readr)
library(here)
concentrado <- read_csv(here("data", "raw", "concentradohogar.csv")) |>
janitor::clean_names()
glimpse(concentrado)
skim(concentrado)
View(concentrado)
# Ajusta los nombres a tu tabla
concentrado |>
select(folioviv:educa_jefe)
# Variables que terminan con "cor" (ejemplo)
concentrado |>
select(ends_with("cor"))
concentrado |>
filter(tam_loc == 1)
names(educa_jefe)
names(concentrado)
#| eval: true
concentrado |>
summarise(
across(
where(is.numeric),
list(media = ~mean(.x, na.rm = TRUE),
mediana = ~median(.x, na.rm = TRUE)),
.names = "{.col}_{.fn}"
)
#| eval: true
concentrado |>
mutate(
across(ing_cor:otras_erog, ~ .x / 1000)
)
View(concentrado)
names(concentrado)
